{
  "name": "deck-passport",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "drizzle-kit migrate && pnpm run db:seed && nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "npx tsx server/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.72",
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.5.1",
    "@oxc-minify/binding-linux-x64-gnu": "0.112.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.112.0",
    "@oxc-transform/binding-linux-x64-gnu": "0.112.0",
    "@types/qrcode": "^1.5.6",
    "@unrs/resolver-binding-linux-x64-gnu": "1.11.1",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "modern-screenshot": "^4.6.8",
    "nuxt": "^4.3.1",
    "pg-error-codes-ts": "^1.0.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "linux",
        "current"
      ],
      "cpu": [
        "x64",
        "current"
      ],
      "libc": [
        "glibc",
        "current"
      ]
    }
  }
}
